# Copy this to .env and fill in your keys — never commit .env to git

# Groq (https://console.groq.com) — free, no CC required
GROQ_API_KEY=gsk_...
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Google AI Studio (https://aistudio.google.com/apikey) — free, no CC
GEMINI_API_KEY=AIza...
GEMINI_EMBED_MODEL=gemini-embedding-2-preview

# Pinecone (https://app.pinecone.io) — free Starter plan, no CC
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=code-explainer
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Retrieval
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.60

# Chunking
CHUNK_TOKEN_LIMIT=512
CHUNK_OVERLAP=64

# Generation
MAX_CONTEXT_TOKENS=6000
